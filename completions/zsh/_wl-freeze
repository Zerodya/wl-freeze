#compdef wl-freeze

_wl-freeze() {
    local curcontext="$curcontext" state line
    local -a options

    _arguments -C \
        '-h[show help message]' \
        '--help[show help message]' \
        '-a[toggle suspend by active window]' \
        '--active[toggle suspend by active window]' \
        '-p[toggle suspend by process id]:pid:_pids' \
        '--pid[toggle suspend by process id]:pid:_pids' \
        '-n[toggle suspend by process name/command]:process name:_command_names' \
        '--name[toggle suspend by process name/command]:process name:_command_names' \
        '-c[toggle suspend by custom command]:custom command: ' \
        '--custom[toggle suspend by custom command]:custom command: ' \
        '-s[do not send notification]' \
        '--silent[do not send notification]' \
        '-t[notification timeout in milliseconds]:timeout:('1000' '2000' '3000' '5000' '10000')' \
        '--notif-timeout[notification timeout in milliseconds]:timeout:('1000' '2000' '3000' '5000' '10000')' \
        '--dry-run[does not actually suspend/resume a process]' \
        '--debug[enable debug mode]' \
        '--no-xorg-workaround[skip the XWayland mouse capture workaround]'

    return 0
}

_wl-freeze "$@"